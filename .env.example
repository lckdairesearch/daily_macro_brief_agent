# Daily Macro Brief Agent — required environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Always required ────────────────────────────────────────────────────────────
# LLM synthesis, web-search scouts, Whisper transcription
OPENAI_API_KEY=

# Optional LiteLLM model overrides.
# Leave blank to use app/config/sources.yaml as the source of truth.
LLM_SCOUT_MODEL=
LLM_X_SCOUT_MODEL=
LLM_SYNTHESIS_MODEL=
LLM_TEMPERATURE=

# ── Required for live / dry-run mode ──────────────────────────────────────────
# Equities, FX, commodities, US Treasury yields, BTC, DXY proxy
ALPHA_VANTAGE_API_KEY=

# Euro Stoxx 50 (FESX/Eurex), German Bund yield (FGBL/Eurex), VIX (VX/CFE)
DATABENTO_API_KEY=

# HY OAS spread — BAMLH0A0HYM2 (free at fred.stlouisfed.org)
FRED_API_KEY=

# X/Grok scout (xAI)
XAI_API_KEY=

# Podcast scout episode discovery (Listen Notes free tier)
LISTEN_NOTES_API_KEY=

# Gemini — podcast/YouTube fallback transcription
GEMINI_API_KEY=

# ── Required for live email delivery ──────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
# Comma-separated list of recipient addresses
SENDGRID_TO_EMAIL=

# ── Delivery toggle ────────────────────────────────────────────────────────────
# Off by default. Set to true only in live mode with confirmed recipients.
ENABLE_EMAIL_DELIVERY=false
