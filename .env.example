# Daily Macro Brief Agent — required environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Always required ────────────────────────────────────────────────────────────
# LLM synthesis, web-search scouts, Whisper transcription
OPENAI_API_KEY=

# Optional LiteLLM model overrides.
# Leave blank to use app/config/sources.yaml as the source of truth.
LLM_SCOUT_MODEL=
LLM_X_SCOUT_MODEL=
LLM_SYNTHESIS_MODEL=
LLM_TEMPERATURE=

# ── Required for live / dry-run mode ──────────────────────────────────────────
# Equities, FX, commodities, US Treasury yields, BTC, DXY proxy
ALPHA_VANTAGE_API_KEY=

# Euro Stoxx 50 (FESX/Eurex), German Bund yield (FGBL/Eurex), VIX (VX/CFE)
DATABENTO_API_KEY=

# HY OAS spread — BAMLH0A0HYM2 (free at fred.stlouisfed.org)
FRED_API_KEY=

# X/Grok scout (xAI)
XAI_API_KEY=

# Podcast scout episode discovery (Taddy GraphQL API — taddy.org)
TADDY_USER_ID=
TADDY_API_KEY=
# LISTEN_NOTES_API_KEY=  # no longer used; kept for reference only

# Gemini — podcast/YouTube fallback transcription
GEMINI_API_KEY=

# ── Required for live email delivery ──────────────────────────────────────────
POSTMARK_API_KEY=
POSTMARK_FROM_EMAIL=
# Comma-separated list of recipient addresses
POSTMARK_TO_EMAIL=

# ── Delivery toggle ────────────────────────────────────────────────────────────
# Off by default. Set to true only in live mode with confirmed recipients.
ENABLE_EMAIL_DELIVERY=false

# ── GitHub chart hosting (inline email images) ─────────────────────────────────
# Repo must be public for raw.githubusercontent.com to serve without auth.
# GITHUB_TOKEN is only needed in CI; local runs use existing git credentials.
GITHUB_TOKEN=
GITHUB_REPO=lckdairesearch/daily_macro_brief_agent
GITHUB_BRANCH=master
