# Daily Macro Brief Agent — required environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Always required ────────────────────────────────────────────────────────────
# LLM synthesis, web-search scouts, Whisper transcription
OPENAI_API_KEY=

# Optional LiteLLM model overrides.
# Leave blank to use app/config/sources.yaml as the source of truth.
LLM_SCOUT_MODEL=
LLM_X_SCOUT_MODEL=
LLM_SYNTHESIS_MODEL=
LLM_TEMPERATURE=
LLM_SYNTHESIS_TEMPERATURE=
LLM_SYNTHESIS_REASONING_EFFORT=
LLM_SYNTHESIS_VERBOSITY=
LLM_SYNTHESIS_TIMEOUT_SECONDS=
LLM_SYNTHESIS_REVIEW_ENABLED=
LLM_SYNTHESIS_REVIEW_MODEL=
LLM_SYNTHESIS_REVIEW_TEMPERATURE=
LLM_SYNTHESIS_REVIEW_REASONING_EFFORT=
LLM_SYNTHESIS_REVIEW_VERBOSITY=
LLM_SYNTHESIS_REVIEW_TIMEOUT_SECONDS=
LLM_SYNTHESIS_CONTEXT_CARD_COUNT=

# ── Required for live / dry-run mode ──────────────────────────────────────────
# Equities, FX, commodities, US Treasury yields, BTC, DXY proxy
ALPHA_VANTAGE_API_KEY=

# German Bund yield (FGBL/Eurex) and copper (HG/CME) futures-derived data
DATABENTO_API_KEY=

# HY OAS spread — BAMLH0A0HYM2 (free at fred.stlouisfed.org)
FRED_API_KEY=

# X/Grok scout (xAI)
XAI_API_KEY=

# Podcast scout episode discovery (Taddy GraphQL API — taddy.org)
TADDY_USER_ID=
TADDY_API_KEY=
# LISTEN_NOTES_API_KEY=  # no longer used; kept for reference only

# Gemini — podcast/YouTube fallback transcription
GEMINI_API_KEY=

# ── Required for live email delivery ──────────────────────────────────────────
POSTMARK_API_KEY=
POSTMARK_FROM_EMAIL=
# Maintainer/test recipient for sample and dry-run sends.
POSTMARK_MAINTAINER_EMAIL=contact@leonard-dai.com
# Comma-separated production recipient list for live sends.
POSTMARK_TO_EMAIL=

# ── Delivery toggle ────────────────────────────────────────────────────────────
# Off by default. Set to true only in live mode with confirmed production recipients.
ENABLE_EMAIL_DELIVERY=false

# ── Cloudflare R2 chart hosting (preferred for Gmail/public rendering) ────────
# Upload endpoint uses the S3-compatible R2 API.
# Public URL can be either your custom domain or the bucket's r2.dev URL.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
# Optional object prefix inside the bucket. Defaults to "charts".
CLOUDFLARE_R2_PREFIX=
